# =============================================================================
# Lingua Platform — Environment variables
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# =============================================================================

# --- MySQL ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme_strong_password
MYSQL_DATABASE=lingua_db
MYSQL_USER=lingua
MYSQL_PASSWORD=changeme_strong_password

# --- Backend (Quarkus) ---------------------------------------------------
# Read by application.properties via ${...} placeholders
DB_USERNAME=root
DB_PASSWORD=changeme_strong_password
DB_JDBC_URL=jdbc:mysql://localhost:3307/lingua_db?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false

# Redis
REDIS_URL=redis://localhost:6380

# CORS — comma-separated list of allowed frontend origins.
# BUG-BE-05: in production this MUST be the real frontend domain(s);
# leaving the localhost defaults will block every browser request.
# Examples:
#   CORS_ORIGINS=https://lingua.yourdomain.com
#   CORS_ORIGINS=https://lingua.yourdomain.com,https://www.lingua.yourdomain.com
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# JWT — token lifespan in seconds (3600 = 1 hour)
JWT_LIFESPAN_SECONDS=3600
JWT_ISSUER=lingua-platform

# Refresh token lifespan in seconds (2592000 = 30 days)
REFRESH_LIFESPAN_SECONDS=2592000

# BUG-BE-02: where Quarkus loads the JWT signing/verifying keys from.
# In production these MUST point to a mounted secret (e.g. /run/secrets/...).
# NEVER bake the private key into the JAR / Docker image / git repo.
# Defaults below match the local-dev convention (resources/privateKey.pem,
# which is git-ignored).
JWT_PRIVATE_KEY_LOCATION=secrets/privateKey.pem
JWT_PUBLIC_KEY_LOCATION=META-INF/resources/publicKey.pem

# --- Docker Compose (BUG-11) ---------------------------------------------
# Cổng host expose cho backend / frontend khi chạy `docker compose up`
BACKEND_PORT=8080
FRONTEND_PORT=80

# Bật Flyway migrate khi backend container start (BUG-01: đã hỗ trợ MySQL 8.0)
FLYWAY_ENABLED=true
FLYWAY_MIGRATE_AT_START=true

# --- Database connection pool (TECH-07) ----------------------------------
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_ACQ_TIMEOUT=30
